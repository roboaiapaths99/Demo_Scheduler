# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tutorAvailability?retryWrites=true&w=majority

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-key-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM_NAME=Tutor Availability System
EMAIL_FROM_EMAIL=your-email@gmail.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5000
EMAIL_FROM=noreply@tutorsystem.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Production Settings
NODE_ENV=production
HOST=0.0.0.0
TRUST_PROXY=true

# Database Production
DB_MAX_POOL_SIZE=10
DB_SERVER_SELECTION_TIMEOUT=5000
DB_SOCKET_TIMEOUT=45000

# Security Production
BCRYPT_ROUNDS=12
SESSION_SECRET=your-super-secret-session-key
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14
LOG_DATE_PATTERN=YYYY-MM-DD

# Monitoring
MONITORING_ENABLED=true
MONITORING_WEBHOOK=https://your-monitoring-webhook.com
HEALTH_CHECK_INTERVAL=30000
METRICS_RETENTION=604800000

# Performance
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
REQUEST_TIMEOUT=30000
KEEP_ALIVE_TIMEOUT=5000
MAX_CONNECTIONS=100

# Cache
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf
UPLOAD_PATH=uploads/

# Backup
BACKUP_PATH=backups
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true

# Cleanup
LOG_RETENTION_DAYS=14
UPLOAD_RETENTION_DAYS=30
TEMP_RETENTION_DAYS=1
NOTIFICATION_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=30
